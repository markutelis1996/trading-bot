# Copy this to .env locally for testing. File is gitignored.
# In cloud routines, set these as environment variables on the routine itself - do NOT create a .env file in the cloud.

# Alpaca (LIVE or paper trading)
# Paper: https://paper-api.alpaca.markets/v2
# Live:  https://api.alpaca.markets/v2
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Perplexity (research) - optional, scripts fall back to WebSearch if unset
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Telegram (notifications - posts to a chat via bot)
# Get TELEGRAM_BOT_TOKEN from @BotFather in Telegram after /newbot
# Get TELEGRAM_CHAT_ID by messaging your bot then calling:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
